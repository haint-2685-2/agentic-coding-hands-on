# Copy to `supabase/.env.local` and fill values. Already in .gitignore.
# For mock OIDC testing (integration tests):
#   - leave the GOOGLE_URL pointed at the mock server's discovery endpoint
#   - any non-empty CLIENT_ID/SECRET works since the mock issues tokens without secret validation

SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=dev-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=dev-google-secret
# Pointed at the mock OIDC server during tests (tests/_shared/mock-oidc.ts boots it on a random port).
# For real Google: leave blank to use Google's default endpoints.
SUPABASE_AUTH_EXTERNAL_GOOGLE_URL=

# For the optional `supabase functions serve` command:
# OPENAI_API_KEY=
